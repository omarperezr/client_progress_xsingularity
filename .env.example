# Postgres connection string (Neon, Supabase, or any Postgres).
# For serverless (Vercel) use a pooled connection string.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=verify-full"

# Secret used to sign session cookies. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET="change-me"

# Admin panel login (/admin). Not stored in the database — change per environment.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-too"

# Two-way comments post under the repo token, so tokens now need WRITE scope
# (GitHub Issues: Read & write / GitLab Developer role + api). Read-only tokens
# still power the dashboard; posting a comment just fails with a clear message.

# Email ("ask the team about this task"). Leave RESEND_API_KEY empty to hide the
# email button — comments still work. Sign up at https://resend.com, verify a
# sending domain, then set:
RESEND_API_KEY=""
MAIL_FROM="Client Progress <progress@yourdomain.com>"
TEAM_EMAIL="team@xsingularity.com"
